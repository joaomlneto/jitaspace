// EVE Online manufacturing/research blueprints (from the SDE blueprints.yaml).
// A blueprint has one row per activity (manufacturing, copying, research, etc.),
// and each activity has its input materials, output products and required skills.
enum BlueprintActivityType {
  copying
  invention
  manufacturing
  reaction
  research_material
  research_time
}

model Blueprint {
  blueprintTypeId    Int                 @id
  blueprintType      Type                @relation("BlueprintType", fields: [blueprintTypeId], references: [typeId])
  maxProductionLimit Int
  activities         BlueprintActivity[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt()
  isDeleted          Boolean             @default(false)
}

model BlueprintActivity {
  blueprintTypeId Int
  blueprint       Blueprint             @relation(fields: [blueprintTypeId], references: [blueprintTypeId])
  activity        BlueprintActivityType
  time            Int
  materials       BlueprintMaterial[]
  products        BlueprintProduct[]
  skills          BlueprintSkill[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt()
  isDeleted       Boolean               @default(false)

  @@id([blueprintTypeId, activity])
}

model BlueprintMaterial {
  blueprintTypeId   Int
  activity          BlueprintActivityType
  blueprintActivity BlueprintActivity     @relation(fields: [blueprintTypeId, activity], references: [blueprintTypeId, activity])
  materialTypeId    Int
  materialType      Type                  @relation("BlueprintMaterials", fields: [materialTypeId], references: [typeId])
  quantity          Int
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt()
  isDeleted         Boolean               @default(false)

  @@id([blueprintTypeId, activity, materialTypeId])
  @@index([materialTypeId])
}

model BlueprintProduct {
  blueprintTypeId   Int
  activity          BlueprintActivityType
  blueprintActivity BlueprintActivity     @relation(fields: [blueprintTypeId, activity], references: [blueprintTypeId, activity])
  productTypeId     Int
  productType       Type                  @relation("BlueprintProducts", fields: [productTypeId], references: [typeId])
  quantity          Int
  // Probability of a successful invention run; only set for `invention` products.
  probability       Float?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt()
  isDeleted         Boolean               @default(false)

  @@id([blueprintTypeId, activity, productTypeId])
  @@index([productTypeId])
}

model BlueprintSkill {
  blueprintTypeId   Int
  activity          BlueprintActivityType
  blueprintActivity BlueprintActivity     @relation(fields: [blueprintTypeId, activity], references: [blueprintTypeId, activity])
  skillTypeId       Int
  skillType         Type                  @relation("BlueprintSkills", fields: [skillTypeId], references: [typeId])
  level             Int
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt()
  isDeleted         Boolean               @default(false)

  @@id([blueprintTypeId, activity, skillTypeId])
  @@index([skillTypeId])
}

