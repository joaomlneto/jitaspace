    "unbzip2-stream": "^1.4.3",
    "untar-to-memory": "^2.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@jitaspace/eslint-config": "workspace:*",
    "@jitaspace/prettier-config": "workspace:*",
    "@jitaspace/tsconfig": "workspace:*",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/tar-stream": "^3.1.4",
    "@types/unbzip2-stream": "^1.4.3",
    "eslint": "^9.39.4",
