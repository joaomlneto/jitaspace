{
  "name": "@jitaspace/eve-scrape",
  "description": "Inngest adapter that runs @jitaspace/background-jobs on Inngest",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "dev": "pnpm with-env npx --ignore-scripts=false inngest-cli@latest dev",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "lint:fix": "pnpm lint --fix",
    "test": "jest",
    "type-check": "tsc --jsx react-jsx --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@jitaspace/background-jobs": "workspace:*",
    "inngest": "^4.5.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@jitaspace/eslint-config": "workspace:*",
    "@jitaspace/prettier-config": "workspace:*",
    "@jitaspace/tsconfig": "workspace:*",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.4",
    "inngest-cli": "^1.22.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "prettier": "@jitaspace/prettier-config"
}
