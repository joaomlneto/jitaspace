    "@jitaspace/kv": "workspace:*",
    "@jitaspace/sde-client": "workspace:*",
    "axios": "^1.16.1",
    "decimal.js": "^10.6.0",
    "inngest": "^4.5.0",
    "p-limit": "^7.3.0",
