{
  "name": "@jitaspace/esi-metadata",
  "description": "Static metadata for the EVE Online ESI API — typed OAuth2 scopes and entity ID ranges",
  "version": "0.2.2",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joaomlneto/jitaspace.git",
    "directory": "packages/esi-metadata"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "kubb:generate": "tsx scripts/generate-scopes.ts",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "lint:fix": "pnpm lint --fix",
    "prepublishOnly": "pnpm build",
    "type-check": "tsc --jsx react-jsx --noEmit",
    "test": "jest"
  },
  "dependencies": {},
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@jitaspace/eslint-config": "workspace:*",
    "@jitaspace/prettier-config": "workspace:*",
    "@jitaspace/tsconfig": "workspace:*",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.1.6",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "prettier": "@jitaspace/prettier-config"
}
