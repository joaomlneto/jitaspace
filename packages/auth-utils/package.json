{
  "name": "@jitaspace/auth-utils",
  "description": "Framework-agnostic EVE Online SSO token utilities and Zod schemas — exchange, refresh, and decode ESI access tokens",
  "version": "0.2.0",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joaomlneto/jitaspace.git",
    "directory": "packages/auth-utils"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts",
    "dev": "tsup index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "lint:fix": "pnpm lint --fix",
    "prepublishOnly": "pnpm build",
    "test": "jest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@jitaspace/esi-metadata": "workspace:*",
    "jose": "^6.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@jitaspace/eslint-config": "workspace:*",
    "@jitaspace/prettier-config": "workspace:*",
    "@jitaspace/tsconfig": "workspace:*",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "prettier": "@jitaspace/prettier-config"
}
