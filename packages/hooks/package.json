{
  "name": "@jitaspace/hooks",
  "description": "ESI React Hooks",
  "version": "0.1.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "eslint --flag unstable_native_nodejs_ts_config .",
    "lint:fix": "pnpm lint --fix",
    "prepublishOnly": "pnpm build",
    "type-check": "tsc --jsx react-jsx --noEmit"
  },
  "dependencies": {
    "@jitaspace/auth-utils": "workspace:*",
    "@jitaspace/esi-client": "workspace:*",
    "@jitaspace/esi-metadata": "workspace:*",
    "@jitaspace/evetycoon-client": "workspace:*",
    "@jitaspace/fuzzworks-market-client": "workspace:*",
    "@jitaspace/sde-client": "workspace:*",
    "@react-hook/cache": "^1.1.1",
    "@tanstack/db": "^0.6.4",
    "@tanstack/query-db-collection": "^1.0.36",
    "@tanstack/react-db": "^0.1.82",
    "@tanstack/react-query": "^5.81.5",
    "axios": "^1.9.0",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@jitaspace/eslint-config": "workspace:*",
    "@jitaspace/prettier-config": "workspace:*",
    "@jitaspace/tsconfig": "workspace:*",
    "@types/node": "^24.10.13",
    "@types/react": "^19.1.6",
    "eslint": "^9.39.2",
    "prettier": "^3.5.3",
    "react": "^19.2.3",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "prettier": "@jitaspace/prettier-config"
}
