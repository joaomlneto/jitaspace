{
  "extends": "@jitaspace/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["es2022", "dom", "dom.iterable"],
    // `@jitaspace/chat` ships its entrypoint as `index.tsx`; set `jsx` so the
    // module (and its inferred `ChatInstance` return type) resolves here instead
    // of degrading to an error/`any` type.
    "jsx": "react-jsx",
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json"
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
